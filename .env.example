# BotFather'dan aldığınız token
TELEGRAM_BOT_TOKEN=123456789:ornek-token

# Mesajın gönderileceği kullanıcı veya grup chat ID'si
TELEGRAM_CHAT_ID=123456789

# Siteyi yormamak için en az 30 saniye
CHECK_INTERVAL_SECONDS=60
PAGE_TIMEOUT_SECONDS=30
PAGE_SETTLE_SECONDS=12

# true: arka planda, false: tarayıcı penceresi açık
HEADLESS=true

# Yerel Google Chrome'u kullanmak için "chrome"; Playwright Chromium için boş bırakın
BROWSER_CHANNEL=chrome

# İsteğe bağlı
# PRODUCTS_FILE=/tam/yol/products.json
# STATE_FILE=/tam/yol/state.json
# LOG_LEVEL=INFO
